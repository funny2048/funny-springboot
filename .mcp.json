{
  "mcpServers": {
    "mysql-trade": {
      "command": "npx",
      "type": "stdio",
      "args": [
        "@benborla29/mcp-server-mysql"
      ],
      "env" : {
        "MYSQL_HOST": "localhost:3306/combo",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_PASS": "Astack@123",
        "MYSQL_DB": "combo",
        "ALLOW_INSERT_OPERATION": "false",
        "ALLOW_UPDATE_OPERATION": "false",
        "ALLOW_DELETE_OPERATION": "false"
      }
    },
    "redis-trade": {
      "command": "npx",
      "type": "stdio",
      "args": [
        "-y",
        "@modelcontextprotocol/server-redis",
        "redis://127.0.01:6379"
      ]
    }
  }
}